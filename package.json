{
  "name": "echo-voice",
  "version": "0.1.0",
  "description": "Phone-first voice input bridge with transcription, refinement, and desktop cursor insertion.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yaoyao2mm/echo-voice.git"
  },
  "bugs": {
    "url": "https://github.com/yaoyao2mm/echo-voice/issues"
  },
  "homepage": "https://github.com/yaoyao2mm/echo-voice#readme",
  "scripts": {
    "start": "node src/server.js",
    "relay": "node src/server.js --relay",
    "desktop": "node src/desktop-agent.js",
    "desktop:app:install": "npm --prefix desktop-app install",
    "desktop:app": "npm --prefix desktop-app start",
    "desktop:mac:app": "bash scripts/macos-create-app.sh",
    "desktop:settings": "node scripts/desktop-settings.js --open",
    "desktop:mac": "bash scripts/macos-desktop-agent.sh",
    "dev": "node --watch src/server.js",
    "android:usb": "node scripts/adb-reverse.js",
    "doctor:network": "node scripts/network-doctor.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "qrcode-terminal": "^0.12.0",
    "undici": "^6.25.0"
  }
}
